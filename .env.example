# Required — generate with: openssl rand -hex 32
PANEL_TOKEN=your-secret-token-here

# Panel domain and CORS origin
PANEL_ALLOWED_ORIGIN=https://panel.yourdomain

# Service URLs (used in health checks and dashboard links)
CHAT_URL=https://chat.yourdomain
AUTH_LINK=https://auth.yourdomain
GRAFANA_URL=http://10.10.x.x:3000
GRAFANA_LINK=https://grafana.yourdomain
NETDATA_LINK=https://netdata.yourdomain
ATLAS_NETDATA_URL=http://10.10.x.x:19998
CLOUDCLI_LINK=https://cloudcli.yourdomain

# Internal host IPs (used for ping checks)
ATLAS_IP=10.10.x.x
UNRAID_IP=10.10.x.x

# TLS cert path (SWAG fullchain, used for expiry check)
TLS_CERT_PATH=/opt/appdata/swag/etc/letsencrypt/live/yourdomain/fullchain.pem

# DNS domains to verify (comma-separated)
DNS_CHECK_DOMAINS=yourdomain,google.com

# Backrest backup manager (optional — leave blank to disable backrest panel)
BACKREST_URL=http://localhost:9898
BACKREST_USERNAME=your-backrest-username
BACKREST_PASSWORD=your-backrest-password

# ntfy notification endpoint for diagnostic failures (optional — leave blank to disable)
NTFY_URL=https://ntfy.example.com/your-topic

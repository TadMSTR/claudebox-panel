# Required — generate with: openssl rand -hex 32
PANEL_TOKEN=your-secret-token-here

# Backrest backup manager (optional — leave blank to disable backrest panel)
BACKREST_URL=http://localhost:9898
BACKREST_USERNAME=your-backrest-username
BACKREST_PASSWORD=your-backrest-password

# ntfy notification endpoint for diagnostic failures (optional — leave blank to disable)
NTFY_URL=https://ntfy.example.com/your-topic
